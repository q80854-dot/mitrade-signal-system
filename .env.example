# ══════════════════════════════════════
# 把這個檔案複製成 .env 並填入你的資訊
# ⚠️ .env 不能上傳到 GitHub！
# ══════════════════════════════════════

# Grok API Key（必填）
# 取得：https://console.x.ai
GROK_API_KEY=在這裡填入你的Grok_API_Key

# Telegram Bot Token（必填）
# 從 @BotFather 取得
TELEGRAM_BOT_TOKEN=在這裡填入你的Bot_Token

# 你的 Telegram Chat ID
TELEGRAM_CHAT_ID=8091656090

# Finnhub API Key（選填，新聞用）
# 取得：https://finnhub.io/register
FINNHUB_API_KEY=

# 帳戶餘額（美元）約 750 USD = 22,500 TWD
ACCOUNT_BALANCE_USD=750
